{
  "name": "@chanho/react",
  "version": "0.2.0",
  "description": "Chanho Design System — React 컴포넌트 라이브러리 (Radix 기반, 토큰 스타일링)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chanho4702/design-system.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/chanho4702/design-system#readme",
  "bugs": "https://github.com/chanho4702/design-system/issues",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles.css": "./dist/styles.css"
    }
  },
  "keywords": [
    "react",
    "design-system",
    "components",
    "radix-ui"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@chanho/tokens": "workspace:*",
    "radix-ui": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^9.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
