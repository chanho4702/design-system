{
  "name": "chanho-design-system",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:tokens": "pnpm --filter @chanho/tokens run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint:css": "stylelint \"packages/react/src/**/*.css\"",
    "storybook": "pnpm build:tokens && pnpm --filter docs run storybook",
    "build-storybook": "pnpm build:tokens && pnpm --filter docs run build-storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && pnpm -r publish --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "stylelint": "^16.26.1"
  }
}
